# =========================
# ASCA-AD / PPLAD Project .gitignore
# Keep source code and scripts; ignore datasets, checkpoints, logs, and generated experiment outputs.
# =========================

# -------------------------
# Dataset / raw data
# -------------------------
dataset/
datasets/
data/
data_raw/
data_clean/
dataset_clean/
raw_data/
processed_data/

# Baseline model data directories
BaselineModels/**/dataset/
BaselineModels/**/datasets/
BaselineModels/**/data/
BaselineModels/**/data_raw/
BaselineModels/**/data_clean/
BaselineModels/**/processed_data/

# -------------------------
# Training outputs / experiment outputs
# -------------------------
runs/
Src/runs/
outputs/
output/
results/
result/
logs/
log/
checkpoints/
checkpoint/
wandb/
tensorboard/
mlruns/

# Baseline model generated outputs
BaselineModels/**/runs/
BaselineModels/**/outputs/
BaselineModels/**/output/
BaselineModels/**/results/
BaselineModels/**/result/
BaselineModels/**/logs/
BaselineModels/**/log/
BaselineModels/**/checkpoints/
BaselineModels/**/checkpoint/
BaselineModels/**/wandb/

# -------------------------
# Model weights / large binary artifacts
# -------------------------
*.pt
*.pth
*.ckpt
*.onnx
*.pkl
*.pickle
*.joblib

# -------------------------
# Array / table data artifacts
# -------------------------
*.npy
*.npz
*.h5
*.hdf5
*.mat
*.csv
*.tsv
*.parquet
*.feather

# -------------------------
# Generated plots / reports under experiment folders
# Do not globally ignore all images/docs, so README assets and paper drafts can still be committed.
# -------------------------
figures/
figure/
plots/
plot_outputs/
reports/generated/
artifacts/

# -------------------------
# Python cache / compiled files
# -------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# -------------------------
# Virtual environments / package build
# -------------------------
.venv/
venv/
env/
ENV/
.conda/
conda/
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# -------------------------
# Jupyter
# -------------------------
.ipynb_checkpoints/
*.ipynb

# -------------------------
# OS / editor / IDE
# -------------------------
.DS_Store
Thumbs.db
.idea/
*.iml
.vscode/

# -------------------------
# Logs / temporary files
# -------------------------
*.log
*.tmp
*.temp
*.swp
*.swo
.cache/
tmp/
temp/

# -------------------------
# Optional: keep selected lightweight result summaries
# Uncomment these lines only if you want to commit final summarized results.
# -------------------------
# !results/ALL_COMBINED_FIXED/summary.md
# !results/ALL_COMBINED_FIXED/all_combined_fixed_metrics.json
# !results/ALL_COMBINED_FIXED/all_combined_fixed_metrics.csv

# =========================
# Local legacy backup / restructuring
# =========================
legacy/
archive/
_restructure_backup/

# Generated comparison runs
comparison_runs/

# Generated one-off experiment files
score.txt
pred.txt
fact.txt
discrepancy.txt
*_score.txt
*_pred.txt
*_fact.txt
*_discrepancy.txt

# Archive packages
*.zip
*.tar
*.tar.gz
*.rar
*.7z
